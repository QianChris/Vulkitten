#version 460 core
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(std430, binding = 0) buffer InputBuf {
    uint inData[];
};
layout(std430, binding = 1) buffer OutputBuf {
    uint outData[];
};
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < 256u) {
        outData[idx] = inData[idx];
    }
}
